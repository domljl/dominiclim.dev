---
import BackToTop from '@/components/BackToTop.svelte';
import LoadingScreen from '@/components/LoadingScreen.svelte';
import LogoLink from '@/components/LogoLink.svelte';
import NavBar from '@/components/NavBar.svelte';
import ThemeToggle from '@/components/ThemeToggle.svelte';
import '@/styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/domLogo.png" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <title>Dominic Lim</title>
        <script is:inline>
            (function () {
                const stored = localStorage.getItem('theme');
                const theme =
                    stored === 'light' || stored === 'dark'
                        ? stored
                        : window.matchMedia('(prefers-color-scheme: dark)').matches
                          ? 'dark'
                          : 'light';
                document.documentElement.classList.add(theme);
                document.documentElement.style.colorScheme = theme;
            })();
        </script>
    </head>
    <body class="antialiased">
        <!-- <LoadingScreen client:only="svelte" visible={true} /> -->
        <header
            class="pointer-events-none fixed top-11 right-4 left-4 z-50 flex items-center justify-between"
        >
            <LogoLink client:load />
            <div
                class="pointer-events-auto lg:absolute lg:left-1/2 lg:w-max lg:max-w-[calc(100%-9rem)] lg:-translate-x-1/2"
            >
                <NavBar client:load />
            </div>
            <div class="pointer-events-auto hidden lg:block">
                <ThemeToggle client:load />
            </div>
        </header>
        <slot />
        <BackToTop client:load />
    </body>
</html>
